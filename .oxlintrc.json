{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "warn"
  },
  "env": {
    "builtin": true
  },
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": "error",
    "@typescript-eslint/consistent-type-imports": "warn",
    "no-unused-vars": "warn",
    // react
    "react/display-name": 0,
    "react/rules-of-hooks": 0,
    "react/only-export-components": ["warn", { "allowConstantExport": true }]
  },
  "ignorePatterns": [
    ".umi",
    ".umi-production",
    ".umi-test",
    "dist",
    "public",
    "node_modules",
    "iconfont.js",
    "packages/docs/.vitepress/cache",
    "components.d.ts"
  ]
}
