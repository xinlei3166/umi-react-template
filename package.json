{
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "postinstall": "max setup",
    "analyze": "ANALYZE=1 max dev",
    "dev": "max dev",
    "build:dev": "cross-env max build",
    "build:github": "cross-env UMI_ENV=github max build",
    "build": "cross-env UMI_ENV=online max build",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "umi-test",
    "test:coverage": "umi-test --coverage",
    "deploy": "zsh scripts/gh-pages.sh"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.5",
    "ahooks": "^3.7.8",
    "antd": "^5.8.4",
    "axios": "^0.27.2",
    "classnames": "^2.3.2",
    "dayjs": "^1.11.9",
    "dva": "^2.4.1",
    "mitt": "^3.0.1",
    "mockjs": "^1.1.0",
    "qs": "^6.11.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "^8.1.2",
    "react-router": "^6.15.0",
    "react-router-dom": "^6.15.0",
    "react-sortablejs": "^6.1.4",
    "redux": "^4.2.1",
    "roadhog-api-doc": "^1.1.2",
    "sortablejs": "^1.15.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.22.10",
    "@babel/plugin-transform-class-properties": "^7.22.5",
    "@types/mockjs": "^1.0.7",
    "@types/qs": "^6.9.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/sortablejs": "^1.15.0",
    "@umijs/fabric": "^4.0.1",
    "@umijs/max": "^4.0.76",
    "@umijs/plugins": "^4.0.78",
    "@umijs/test": "^4.0.76",
    "@unocss/cli": "^0.55.2",
    "@unocss/postcss": "^0.53.5",
    "@unocss/preset-rem-to-px": "^0.53.5",
    "@unocss/webpack": "^0.53.5",
    "cross-env": "^7.0.3",
    "csstype": "^3.1.2",
    "lint-staged": "^10.5.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "picocolors": "latest",
    "postcss": "^8.4.23",
    "simple-git-hooks": "latest",
    "tsx": "latest",
    "typescript": "^4.9.5",
    "unocss": "^0.53.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom",
        "react-redux",
        "dva-core",
        "dva"
      ]
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
